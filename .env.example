# Tauri build: macOS code signing & notarization
# Copy to .env and fill in. See https://v2.tauri.app/distribute/sign/macos/

# Option A: Apple ID (for notarization)
# APPLE_ID=your@apple.id
# APPLE_PASSWORD=app-specific-password
# APPLE_TEAM_ID=XXXXXXXXXX

# Option B: App Store Connect API (for notarization)
# APPLE_API_ISSUER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APPLE_API_KEY=XXXXXXXXXX
# APPLE_API_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8

# Signing (local keychain or CI)
# APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAM_ID)
# For CI: export .p12 from Keychain, then:
# APPLE_CERTIFICATE=base64-encoded-p12-content
# APPLE_CERTIFICATE_PASSWORD=p12-password

# Mac App Store upload (pnpm run appstore:mac)
# Create key in App Store Connect > Users and Access > Integrations > Individual Keys.
# Save private key as AuthKey_<APPLE_API_KEY_ID>.p8 in ~/private_keys, ~/.private_keys, or ~/.appstoreconnect/private_keys
# APPLE_API_KEY_ID=XXXXXXXXXX
# APPLE_API_ISSUER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# INSTALLER_SIGNING_ID: Must be a "3rd Party Mac Developer Installer" cert (different from Developer ID Application).
#   Create it: Apple Developer > Certificates > + > Mac App Store > Mac Installer Distribution.
#   After installing the cert, get the exact name with: security find-identity -v -p codesigning
# INSTALLER_SIGNING_ID=3rd Party Mac Developer Installer: Your Name (TEAM_ID)
